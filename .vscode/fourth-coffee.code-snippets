      "/* Fourth Coffee - Global Styles */",
      "",
      "/* Homepage */",
      ".home h1 { font-size: 3rem; color: #2c1810; }",
      ".home section { margin: 2rem 0; }",
      ".home a { color: #8b4513; font-weight: bold; }",
      "",
      "/* Blog index */",
      ".posts { list-style: none; padding: 0; }",
      ".posts li { margin-bottom: 2rem; padding-bottom: 2rem; border-bottom: 1px solid #eee; }",
      ".posts a { text-decoration: none; color: inherit; }",
      ".posts h2 { color: #2c1810; }",
      ".posts p { color: #888; }",
      "",
      "/* Blog post */",
      ".blog-post { max-width: 700px; }",
      ".blog-post h1 { color: #2c1810; }",
      ".blog-post .meta { color: #888; margin-bottom: 2rem; padding-bottom: 2rem; border-bottom: 1px solid #eee; }",
      ".blog-post a { color: #8b4513; }",
      "",
      "/* Products grid */",
      ".product-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 2rem; }",
      ".product-card { background: #fff; border: 1px solid #e0d6c8; border-radius: 8px; padding: 1.5rem; position: relative; }",

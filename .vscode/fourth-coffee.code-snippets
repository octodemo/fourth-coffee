  "Astro Action - addReview": {
    "scope": "typescript",
    "prefix": "fc-action-review",
    "description": "Astro Action - addReview",
    "body": [
      "import { defineAction } from 'astro:actions';",
      "import { z } from 'astro/zod';",
      "import { db, Review } from 'astro:db';",
      "",
      "export const server = {",
      "  addReview: defineAction({",
      "    input: z.object({",
      "      slug: z.string(),",
      "      author: z.string().min(1),",
      "      rating: z.number().min(1).max(5),",
      "      comment: z.string().min(1),",
      "    }),",
      "    handler: async (input) => {",
      "      const [review] = await db",
      "        .insert(Review)",
      "        .values({",
      "          productSlug: input.slug,",
      "          author: input.author,",
      "          rating: input.rating,",
      "          comment: input.comment,",
      "        })",
      "        .returning();",
      "      return review;",
      "    },",
      "  }),",
      "};"
    ]
  },
  "ReviewList component": {
    "scope": "astro",
    "prefix": "fc-review-list",
    "description": "ReviewList server island component",
    "body": [
      "---",
      "import { db, Review, eq, desc } from 'astro:db';",
      "",
      "interface Props {",
      "  slug: string;",
      "}",
      "const { slug } = Astro.props;",
      "",
      "const reviews = await db",
      "  .select({",
      "    rating: Review.rating,",
      "    comment: Review.comment,",
      "    author: Review.author,",
      "  })",
      "  .from(Review)",
      "  .where(eq(Review.productSlug, slug))",
      "  .orderBy(desc(Review.id));",
      "---",
      "",
      "{reviews.length > 0 && (",
      "  <div class=\"reviews-list\">",
      "    {reviews.map(review => (",
      "      <div class=\"review\">",
      "        <p class=\"stars\">{'★'.repeat(review.rating)}{'☆'.repeat(5 - review.rating)}</p>",
      "        <p class=\"review-comment\">\"{review.comment}\"</p>",
      "        <p class=\"review-author\">— {review.author}</p>",
      "      </div>",
      "    ))}",
      "  </div>",
      ")}"
    ]
  }

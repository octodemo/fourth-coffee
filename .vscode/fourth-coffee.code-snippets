      ".roast-badge[data-roast=\"medium\"] { background: #fed7aa; color: #9a3412; }",
      ".roast-badge[data-roast=\"dark\"] { background: #4a2c1a; color: #fff; }",
      ".product-card h2 { color: #2c1810; padding-right: 80px; }",
      ".product-card .price { font-size: 1.5rem; font-weight: bold; color: #2c1810; }",
      ".product-card .btn { display: inline-block; background: #2c1810; color: #fff; padding: 0.75rem 1.5rem; border-radius: 4px; text-decoration: none; }",
      "",
      "/* Product detail */",
      ".product-detail h1 { color: #2c1810; font-size: 2.5rem; }",
      ".product-detail .price { font-size: 1.5rem; font-weight: bold; color: #2c1810; }",
      ".product-detail .notes { background: #f9f6f1; padding: 1rem; border-radius: 8px; margin: 1rem 0; }",
      ".product-detail a { color: #8b4513; }",
      "",
      "/* Reviews */",
      ".review-form { display: flex; flex-direction: column; gap: 1rem; padding: 1.5rem; background: #fff8f0; border-radius: 8px; max-width: 500px; margin-top: 1.5rem; }",
      ".review-form h4 { margin: 0; color: #2c1810; }",
      ".review-form label { display: flex; flex-direction: column; gap: 0.25rem; font-weight: bold; color: #2c1810; font-size: 0.9rem; }",
      ".review-form input, .review-form textarea { padding: 0.5rem; font-size: 1rem; border: 1px solid #d4c5b0; border-radius: 4px; font-family: inherit; }",
      ".review-form button { background: #2c1810; color: #fff; border: none; padding: 0.75rem 1.5rem; font-size: 1rem; border-radius: 4px; cursor: pointer; align-self: flex-start; }",

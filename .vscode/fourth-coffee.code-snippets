  "StarPicker Svelte component": {
    "scope": "svelte",
    "prefix": "fc-star-picker",
    "description": "Star rating picker Svelte component",
    "body": [
      "<script>",
      "  let { rating = \\$bindable(0) } = \\$props();",
      "  let hoverRating = \\$state(0);",
      "</script>",
      "",
      "<div class=\"star-picker\" role=\"radiogroup\" aria-label=\"Rating\" tabindex=\"0\" onmouseleave={() => hoverRating = 0}>",
      "  {#each [1, 2, 3, 4, 5] as star}",
      "    <span",
      "      class=\"star\"",
      "      role=\"radio\"",
      "      tabindex=\"0\"",
      "      aria-checked={rating === star}",
      "      aria-label=\"{star} star{star > 1 ? 's' : ''}\"",
      "      class:filled={star <= (hoverRating || rating)}",
      "      onmouseenter={() => hoverRating = star}",
      "      onclick={() => rating = star}",
      "      onkeydown={(e) => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); rating = star; } }}",
      "    >★</span>",
      "  {/each}",
      "</div>"
    ]
  },
  "ReviewForm Svelte component": {
    "scope": "svelte",
    "prefix": "fc-review-form",
    "description": "ReviewForm Svelte component",
    "body": [
      "<script>",
      "  import StarPicker from './StarPicker.svelte';",
      "  let { slug } = \\$props();",
      "  let author = \\$state('');",
      "  let rating = \\$state(0);",
      "  let comment = \\$state('');",
      "  let submitted = \\$state(false);",
      "",
      "  function submitReview() {",
      "    console.log(`Review for \\${slug}: \\${author} gives \\${rating} stars — \"\\${comment}\"`);",
      "    submitted = true;",
      "  }",
      "</script>",
      "",
      "{#if submitted}",
      "  <div class=\"review your-review\">",
      "    <span class=\"your-review-badge\">Thanks for your review!</span>",
      "    <p class=\"stars\">{'★'.repeat(rating)}{'☆'.repeat(5 - rating)}</p>",
      "    <p class=\"review-comment\">\"{comment}\"</p>",
      "    <p class=\"review-author\">— {author}</p>",
      "  </div>",
      "{:else}",
      "  <form class=\"review-form\" onsubmit={(e) => { e.preventDefault(); submitReview(); }}>",
      "    <h4>Leave a Review</h4>",
      "    <label>Name<input type=\"text\" bind:value={author} required /></label>",
      "    <StarPicker bind:rating />",
      "    <label>Your thoughts<textarea bind:value={comment} rows=\"3\" required></textarea></label>",
      "    <button type=\"submit\" disabled={rating === 0}>Submit Review</button>",
      "  </form>",
      "{/if}"
    ]
  },

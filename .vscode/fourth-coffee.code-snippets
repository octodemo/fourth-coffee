  "Blog listing page": {
    "scope": "astro",
    "prefix": "fc-blog-index",
    "description": "Blog listing page",
    "body": [
      "---",
      "import BaseLayout from '../../layouts/BaseLayout.astro';",
      "import { getCollection } from 'astro:content';",
      "",
      "const posts = await getCollection('blog');",
      "const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());",
      "---",
      "",
      "<BaseLayout title=\"Blog\">",
      "  <h1>From the Roastery</h1>",
      "  <ul class=\"posts\">",
      "    {sortedPosts.map(post => (",
      "      <li>",
      "        <a href={`/blog/\\${post.id}`}>",
      "          <h2>{post.data.title}</h2>",
      "          <p>By {post.data.author} • {post.data.pubDate.toLocaleDateString()}</p>",
      "        </a>",
      "      </li>",
      "    ))}",
      "  </ul>",
      "</BaseLayout>"
    ]
  },
  "Blog post page": {
    "scope": "astro",
    "prefix": "fc-blog-slug",
    "description": "Blog post page",
    "body": [
      "---",
      "import BaseLayout from '../../layouts/BaseLayout.astro';",
      "import { getCollection, render } from 'astro:content';",
      "",
      "export async function getStaticPaths() {",
      "  const posts = await getCollection('blog');",
      "  return posts.map((post) => ({",
      "    params: { slug: post.id },",
      "    props: { post },",
      "  }));",
      "}",
      "",
      "const { post } = Astro.props;",
      "const { Content } = await render(post);",
      "---",
      "",
      "<BaseLayout title={post.data.title}>",
      "  <article class=\"blog-post\">",
      "    <h1>{post.data.title}</h1>",
      "    <p class=\"meta\">By {post.data.author} • {post.data.pubDate.toLocaleDateString()}</p>",
      "    <Content />",
      "    <a href=\"/blog\">← Back to blog</a>",
      "  </article>",
      "</BaseLayout>"
    ]
  },

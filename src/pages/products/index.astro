---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { db, Product, Review, avg } from 'astro:db';
import {
  buildRatingMap,
  getUniqueRoastTypes,
  filterAndAttachRatings,
  sortProducts,
  buildUrl,
} from '../../lib/products';

const sort = Astro.url.searchParams.get('sort') === 'rating' ? 'rating' : 'name';
const roastFilter = Astro.url.searchParams.get('roast') ?? 'all';

const currentParams = {
  sort: Astro.url.searchParams.get('sort'),
  roast: Astro.url.searchParams.get('roast'),
};

const products = await db
  .select({
    name: Product.name,
    slug: Product.slug,
    price: Product.price,
    roast: Product.roast,
  })
  .from(Product)
  .orderBy(Product.name);

const roastTypes = getUniqueRoastTypes(products);

const avgRatings = await db
  .select({
    productSlug: Review.productSlug,
    avgRating: avg(Review.rating),
  })
  .from(Review)
  .groupBy(Review.productSlug);

const ratingMap = buildRatingMap(avgRatings);

const sortedProducts = filterAndAttachRatings(products, ratingMap, roastFilter);
sortProducts(sortedProducts, sort);
---

<BaseLayout title="Our Coffees">
  <div class="products-header">
    <h1>Our Coffees</h1>
    <div class="filter-sort-bar">
      <div class="filter-control">
        <span>Roast:</span>
        <a href={buildUrl(currentParams, { roast: 'all' })} class:list={[{ active: roastFilter === 'all' }]}>All</a>
        {roastTypes.map(roast => (
          <a href={buildUrl(currentParams, { roast: roast.toLowerCase() })} class:list={[{ active: roastFilter.toLowerCase() === roast.toLowerCase() }]}>{roast}</a>
        ))}
      </div>
      <div class="sort-control">
        <span>Sort by:</span>
        <a href={buildUrl(currentParams, { sort: 'name' })} class:list={[{ active: sort === 'name' }]}>Name</a>
        <a href={buildUrl(currentParams, { sort: 'rating' })} class:list={[{ active: sort === 'rating' }]}>Rating</a>
      </div>
    </div>
  </div>
  <div class="product-grid">
    {sortedProducts.map(p => (
      <article class="product-card">
        <span class="roast-badge" data-roast={p.roast.toLowerCase()}>{p.roast}</span>
        <h2>{p.name}</h2>
        <div class="card-rating">
          <span class="stars">{'★'.repeat(Math.round(p.avgRating))}{'☆'.repeat(5 - Math.round(p.avgRating))}</span>
          <span class="rating-value">{p.avgRating > 0 ? p.avgRating.toFixed(1) : 'No reviews'}</span>
        </div>
        <p class="price">${p.price.toFixed(2)}</p>
        <a class="btn" href={`/products/${p.slug}`}>View Details</a>
      </article>
    ))}
  </div>
</BaseLayout>
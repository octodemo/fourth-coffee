---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductSearch from '../../components/ProductSearch.svelte';
import { db, Product, Review, avg } from 'astro:db';

const products = await db
  .select({
    name: Product.name,
    slug: Product.slug,
    price: Product.price,
    roast: Product.roast,
    origin: Product.origin,
  })
  .from(Product)
  .orderBy(Product.name);

const avgRatings = await db
  .select({
    productSlug: Review.productSlug,
    avgRating: avg(Review.rating),
  })
  .from(Review)
  .groupBy(Review.productSlug);

const ratingMap = new Map(avgRatings.map(r => [r.productSlug, Number(r.avgRating) || 0]));

const productsWithRatings = products.map(p => ({
  ...p,
  avgRating: ratingMap.get(p.slug) ?? 0,
}));
---

<BaseLayout title="Our Coffees">
  <div class="products-header">
    <h1>Our Coffees</h1>
  </div>

  <ProductSearch client:load />

  <div class="product-grid" id="product-grid">
    {productsWithRatings.map(p => (
      <article
        class="product-card"
        data-name={p.name.toLowerCase()}
        data-origin={p.origin.toLowerCase()}
        data-roast={p.roast.toLowerCase()}
      >
        <span class="roast-badge" data-roast={p.roast.toLowerCase()}>{p.roast}</span>
        <h2>{p.name}</h2>
        <div class="card-rating">
          <span class="stars">{'★'.repeat(Math.round(p.avgRating))}{'☆'.repeat(5 - Math.round(p.avgRating))}</span>
          <span class="rating-value">{p.avgRating > 0 ? p.avgRating.toFixed(1) : 'No reviews'}</span>
        </div>
        <p class="price">${p.price.toFixed(2)}</p>
        <a class="btn" href={`/products/${p.slug}`}>View Details</a>
      </article>
    ))}
  </div>
</BaseLayout>